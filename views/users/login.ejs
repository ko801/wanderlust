<% layout("layouts/boilerplate") %>
<div class="row mt-3">
    <h2 class="col-6 offset-3">Login</h2>
    <div class="col-8 offset-2">
        <form action="/login" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
        <label for="username" class="form-label">username</label>
        <input name="username" placeholder="enter your  username" type="text" class="form-control" id="username" required>
        </div>

        <div class="mb-3">
        <label for="password" class="form-label">password</label>
        <input name="password" placeholder="enter your  password" type="password" class="form-control" id="password" required>
        </div>

        <button class="btn btn-success">
           login 
        </button>
        
        <br><br>
     </form>
     <br><br><br><br><br><br>
</div>