<% layout("layouts/boilerplate") %>
<div class="row mt-3">
    <h2 class="col-6 offset-3">SignUp on Wanderlust</h2>
    <div class="col-8 offset-2">
        <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
        <label for="username" class="form-label">username</label>
        <input name="username" placeholder="enter your  username" type="text" class="form-control" id="username" required>
        <div class="valid-feedback"> Looks Good!</div>
        </div>

        <div class="mb-3">
        <label for="email" class="form-label">email</label>
        <input name="email" placeholder="enter your  email" type="email" class="form-control" id="email" required>
        
        </div>

        <div class="mb-3">
        <label for="password" class="form-label">password</label>
        <input name="password" placeholder="enter your  password" type="password" class="form-control" id="password" required>
        </div>
        <button class="btn btn-success">
           SignUp 
        </button>
        <br><br>
     </form>
     <br><br><br><br><br><br>
</div>