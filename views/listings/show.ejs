<style>
.edit-btn{
    color: white;
}
</style>

<% layout("layouts/boilerplate") %>

<div class="container mt-4">

    <!-- TITLE -->
    <div class="row mb-3">
        <div class="col-12 text-center">
            <h2><b><%= listing.title %></b></h2>
        </div>
    </div>

    <!-- MAIN CARD -->
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">

            <div class="card listing-card show-card">

                <img
                    src="<%= listing.image.url %>"
                    class="card-img-top show-img"
                    alt="listing_image"
                >

                <div class="card-body p-3">

                    <p class="card-text">
                        <i>Owned by:</i>
                        <%= listing.owner?.username || "Unknown Owner" %>
                    </p>

                    <p class="card-text">
                        <%= listing.description %>
                    </p>

                    <p class="card-text">
                        &#8377; <%= listing.price.toLocaleString("en-IN") %>
                    </p>

                    <p class="card-text">
                        <%= listing.location %>
                    </p>

                    <p class="card-text">
                        <%= listing.country %>
                    </p>

                </div>
            </div>

            <!-- BUTTONS -->
            <% if(currUser && listing.owner?._id && listing.owner._id.equals(currUser._id)){ %>

            <div class="btns mt-4 edit-btn">

                <a
                    href="/listings/<%= listing._id %>/edit"
                    class="btn btn-dark edit-btn"
                >
                    Edit
                </a>

                <form
                    method="POST"
                    action="/listings/<%= listing._id %>?_method=DELETE"
                    class="delete-form"
                >
                    <button type="submit" class="btn btn-danger delete-btn">
                        Delete
                    </button>
                </form>

            </div>

            <% } %>

        </div>
    </div>

    <!-- MAP -->
    <div class="row mt-4 justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <h4 class="text-center mb-3">Where you'll be</h4>
            <div id="listing-map"></div>
        </div>
    </div>

    <script>
        const mapCoordinates = {
            lat: <%= listing.geometry ? listing.geometry.coordinates[1] : 28.6139 %>,
            lng: <%= listing.geometry ? listing.geometry.coordinates[0] : 77.2090 %>
        };
        const listingTitle = "<%= listing.title %>";
        const listingLocation = "<%= listing.location %>";
    </script>

    <script src="/js/map.js"></script>

    <!-- REVIEW FORM -->
    <div class="row mt-4 justify-content-center">

        <div class="col-lg-8 col-md-10 col-sm-12">

            <% if(currUser){ %>

            <hr>

            <h4>Leave a Review</h4>

            <form
                action="/listings/<%= listing._id %>/reviews"
                method="POST"
                class="needs-validation"
                novalidate
            >

                <fieldset class="starability-slot mb-3">
                    <legend>Rating</legend>

                    <input type="radio" id="r0" class="input-no-rate" name="review[rating]" value="0" checked>

                    <input type="radio" id="r1" name="review[rating]" value="1">
                    <label for="r1">1 star</label>

                    <input type="radio" id="r2" name="review[rating]" value="2">
                    <label for="r2">2 stars</label>

                    <input type="radio" id="r3" name="review[rating]" value="3">
                    <label for="r3">3 stars</label>

                    <input type="radio" id="r4" name="review[rating]" value="4">
                    <label for="r4">4 stars</label>

                    <input type="radio" id="r5" name="review[rating]" value="5">
                    <label for="r5">5 stars</label>

                </fieldset>

                <textarea
                    name="review[comment]"
                    class="form-control mb-2"
                    rows="4"
                    required
                    placeholder="Write your review..."
                ></textarea>

                <button class="btn btn-outline-dark">
                    Submit
                </button>

            </form>

            <hr>

            <% } %>

        </div>
    </div>

    <!-- REVIEWS -->
    <% if(listing.reviews.length > 0){ %>

    <div class="row justify-content-center mt-3">

        <div class="col-lg-8 col-md-10 col-sm-12">

            <h4>All Reviews</h4>

            <div class="row g-3">

                <% for(let review of listing.reviews){ %>

                <div class="col-md-6 col-sm-12">

                    <div class="card h-100 review-card">

                        <div class="card-body">

                            <h6>@<%= review.author?.username || "Anonymous" %></h6>

                            <p><%= review.comment %></p>

                            <p><b><%= review.rating %> ⭐</b></p>

                            <p class="starability-result" data-rating="<%= review.rating %>">
                                Rated: <%= review.rating %>
                            </p>

                        </div>

                        <% if(currUser && review.author && review.author._id.equals(currUser._id)){ %>

                        <form
                            method="POST"
                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            class="p-2"
                        >
                            <button class="btn btn-sm btn-danger w-100">
                                Delete
                            </button>
                        </form>

                        <% } %>

                    </div>

                </div>

                <% } %>

            </div>

        </div>

    </div>

    <% } %>

</div>