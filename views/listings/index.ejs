<% layout("layouts/boilerplate") %>
<style>
  #filters{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .filter{
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    opacity: 0.7;
    cursor: pointer;
  }
  .filter:hover{
    opacity: 1;
    cursor: pointer;
  }
  .filter p{
    font-size: 0.8rem;
  }
  .filter.active{
    opacity: 1;
    border-bottom: 2px solid black;
    padding-bottom: 4px;
  }
  .tax-info{
    display: none;
  }
  .tax-toggle {
    border: 1px solid #ddd;
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
    font-size: 0.85rem;
    white-space: nowrap;
    background: #fff;
}
.form-check-input {
    transform: scale(0.8);
}
@media (max-width: 992px) {
    .tax-toggle {
        margin-left: 0;
        width: fit-content;
        margin-top: 1rem;
        justify-content: center;
    }
}
</style>

<div id="filters">
  <div class="filter <%= currCategory === 'Trending' ? 'active' : '' %>" data-category="Trending">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </div>
  <div class="filter <%= currCategory === 'Rooms' ? 'active' : '' %>" data-category="Rooms">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </div>
  <div class="filter <%= currCategory === 'Iconic cities' ? 'active' : '' %>" data-category="Iconic cities">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic cities</p>
  </div>
  <div class="filter <%= currCategory === 'Mountains' ? 'active' : '' %>" data-category="Mountains">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </div>
  <div class="filter <%= currCategory === 'Castles' ? 'active' : '' %>" data-category="Castles">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
  </div>
  <div class="filter <%= currCategory === 'Pool side' ? 'active' : '' %>" data-category="Pool side">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Pool side</p>
  </div>
  <div class="filter <%= currCategory === 'Camping' ? 'active' : '' %>" data-category="Camping">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </div>
  <div class="filter <%= currCategory === 'Farm' ? 'active' : '' %>" data-category="Farm">
    <div><i class="fa-solid fa-seedling"></i></div>
    <p>Farm</p>
  </div>
  <div class="filter <%= currCategory === 'Artic' ? 'active' : '' %>" data-category="Artic">
  <div><i class="fa-regular fa-snowflake"></i></div>
  <p>Artic</p>
</div>

<div class="filter <%= currCategory === 'Domes' ? 'active' : '' %>" data-category="Domes">
  <div><i class="fa-solid fa-igloo"></i></div>
  <p>Domes</p>
</div>

<div class="filter <%= currCategory === 'Boats' ? 'active' : '' %>" data-category="Boats">
  <div><i class="fa-solid fa-ship"></i></div>
  <p>Boats</p>
</div>
  

  <div class="tax-toggle">
    <div class="form-check form-check-reverse">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display Total after taxes</label>
    </div>
  </div>
</div>

<!-- No listings found message -->
<% if(allListings.length === 0) { %>
  <div class="text-center mt-5">
    <h4>No listings found for this category!</h4>
    <a href="/listings" class="btn btn-dark mt-3">Show all listings</a>
  </div>
<% } %>

<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 mt-3">
  <% for(let listing of allListings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card" style="width: 20rem;">
        <img
          src="<%= listing.image?.url || listing.image || 'https://via.placeholder.com/300' %>"
          class="card-img-top"
          alt="listing_image"
          style="height:20rem"
        >
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b>
            <br>
            &#8377; <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> /night
            <i class="tax-info"> &nbsp; &nbsp;+18% GST </i>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");

  taxSwitch.addEventListener("change", () => {
    let taxInfo = document.querySelectorAll(".tax-info");

    taxInfo.forEach((info) => {
      info.style.display = taxSwitch.checked ? "inline" : "none";
    });
  });


  // Filter click — redirect with category query
  let filters = document.querySelectorAll(".filter");
  filters.forEach((filter) => {
    filter.addEventListener("click", () => {
      let category = filter.dataset.category;
      window.location.href = `/listings?category=${encodeURIComponent(category)}`;
    });
  });
</script>
